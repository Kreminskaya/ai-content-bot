# ═══════════════════════════════════════════════════
#  AI Content Bot — environment variables template
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ═══════════════════════════════════════════════════

# ── LLM provider ───────────────────────────────────
LLM_PROVIDER=openrouter              # openrouter | anthropic | openai | deepseek | ofoxai
OPENROUTER_API_KEY=sk-or-...         # for OpenRouter (recommended — one key for all models)
ANTHROPIC_API_KEY=sk-ant-...         # for Anthropic direct
OPENAI_API_KEY=sk-proj-...           # for OpenAI direct
DEEPSEEK_API_KEY=                    # for DeepSeek direct
LLM_MODEL_NAME=deepseek/deepseek-chat-v3-0324  # model id (OpenRouter format or provider format)

# ── Telegram Bot (aiogram) ──────────────────────────
TELEGRAM_BOT_TOKEN=                  # ← REPLACE: token from @BotFather
ADMIN_CHAT_ID=123456789              # ← REPLACE: your Telegram user_id (get it from @userinfobot)
TARGET_CHANNEL_ID=@your_channel      # ← REPLACE: @username or -100... channel id

# ── Telegram Userbot (Telethon) ─────────────────────
TELEGRAM_API_ID=                     # ← REPLACE: from my.telegram.org → App api_id
TELEGRAM_API_HASH=                   # ← REPLACE: from my.telegram.org → App api_hash
TELEGRAM_PHONE=+1XXXXXXXXXX          # ← REPLACE: your phone number with country code

# ── Language ────────────────────────────────────────
LANGUAGE=en                          # default interface & content language: ru or en
                                     # users can switch any time via /language in the bot

# ── Optional settings ───────────────────────────────
ENABLE_VISUAL_PROMPT=true            # false — disable image prompt generation
LLM_DAILY_BUDGET_USD=5.0             # soft daily spend limit (logged, not enforced)
USERBOT_SESSION=userbot.session      # Telethon session filename (no need to change)
MEDIA_DIR=media                      # media download folder (no need to change)

# ── Additional sources (optional, disabled by default) ──────────────────────
# GitHub trending repos — comma-separated topic tags for your niche
# AI:     GITHUB_TRENDING_TOPICS=machine-learning,llm,ai-agent
# Fashion: GITHUB_TRENDING_TOPICS=fashion,style,clothing
# GITHUB_TRENDING_TOPICS=

# HuggingFace daily papers + trending models
# HUGGINGFACE_DAILY_PAPERS_LIMIT=8
# HUGGINGFACE_TRENDING_MODELS_LIMIT=6

# Product Hunt feed
# PRODUCT_HUNT_URL=https://www.producthunt.com/topics/artificial-intelligence

# ═══════════════════════════════════════════════════
#  AI Telegram Assistant — шаблон переменных окружения
#  Скопируй этот файл в .env и заполни своими значениями
# ═══════════════════════════════════════════════════

# ── LLM (Anthropic / OpenAI) ───────────────────────
LLM_PROVIDER=anthropic              # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...        # для Anthropic
OPENAI_API_KEY=sk-proj-...          # для OpenAI
LLM_MODEL_NAME=deepseek-chat         # примеры: deepseek-chat | gpt-4o-mini | qwen-plus

# ── Telegram Bot (aiogram) ──────────────────────────
TELEGRAM_BOT_TOKEN=                 # ← ЗАМЕНИТЬ: токен от @BotFather
ADMIN_CHAT_ID=123456789             # ← ЗАМЕНИТЬ: твой Telegram user_id (узнать у @userinfobot)
TARGET_CHANNEL_ID=@your_channel     # ← ЗАМЕНИТЬ: @username или -100... id канала

# ── Telegram Userbot (Telethon) ─────────────────────
TELEGRAM_API_ID=                    # ← ЗАМЕНИТЬ: из my.telegram.org → App api_id
TELEGRAM_API_HASH=                  # ← ЗАМЕНИТЬ: из my.telegram.org → App api_hash
TELEGRAM_PHONE=+7XXXXXXXXXX         # ← ЗАМЕНИТЬ: твой номер телефона в формате +7...

# ── Необязательные ──────────────────────────────────
CONTENT_LANGUAGE=Russian            # язык постов: Russian, English, Spanish, etc.
ENABLE_VISUAL_PROMPT=true           # false — отключить генерацию промптов для картинок
LLM_DAILY_BUDGET_USD=5.0            # лимит расходов в день (не жёсткий, только лог)
USERBOT_SESSION=userbot.session     # имя файла сессии Telethon (не менять)
MEDIA_DIR=media                     # папка для скачанных медиафайлов (не менять)

# ── Дополнительные источники (опционально, по умолчанию отключены) ──
# GitHub trending repos — укажи теги через запятую под свою нишу
# AI: GITHUB_TRENDING_TOPICS=machine-learning,llm,ai-agent
# Fashion: GITHUB_TRENDING_TOPICS=fashion,style,clothing-store
# GITHUB_TRENDING_TOPICS=

# HuggingFace daily papers + trending models (только для AI-каналов)
# HUGGINGFACE_DAILY_PAPERS_LIMIT=8
# HUGGINGFACE_TRENDING_MODELS_LIMIT=6

# Product Hunt (AI tools feed, только для AI-каналов)
# PRODUCT_HUNT_URL=https://www.producthunt.com/topics/artificial-intelligence
